# Copy to .env and fill in. Never commit the real .env (gitignored).

# Server
PORT=4000

# PostgreSQL + PostGIS
DATABASE_URL=postgres://user:password@localhost:5432/manhole_tracker

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Image storage (S3 / Cloudinary / Firebase) — images are NOT stored in Postgres
# e.g. Cloudinary
CLOUDINARY_URL=
