{
  "name": "manhole-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Manhole tracking app — monorepo (React Native mobile app + Node/Express backend)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "backend": "npm run dev --workspace=apps/backend",
    "backend:dev": "npm run dev --workspace=apps/backend",
    "backend:migrate": "npm run migrate --workspace=apps/backend",
    "lint": "npm run lint --workspace=apps/mobile"
  },
  "license": "ISC",
  "type": "module"
}
